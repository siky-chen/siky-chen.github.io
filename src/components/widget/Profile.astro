---
import { Icon } from "astro-icon/components";
import { profileConfig } from "../../config";
import { url } from "../../utils/url-utils";
import ImageWrapper from "../misc/ImageWrapper.astro";
import TypewriterText from "../TypewriterText.astro";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";

const wechatQrUrl = "/assets/contact/wechat-qr.webp";
---

<div class="profile-card-widget">
<div class="card-base p-3">
    <a aria-label="Go to About Page" href={url('/about/')}
       class="group block relative mx-auto mt-1 lg:mx-0 lg:mt-0 mb-3
       max-w-48 lg:max-w-none overflow-hidden rounded-xl active:scale-95">
        <div class="absolute transition pointer-events-none group-hover:bg-black/30 group-active:bg-black/50
        w-full h-full z-50 flex items-center justify-center">
            <Icon name="fa7-regular:address-card"
                  class="transition opacity-0 scale-90 group-hover:scale-100 group-hover:opacity-100 text-white text-5xl">
            </Icon>
        </div>
        <ImageWrapper src={profileConfig.avatar || ""} alt="Profile Image of the Author" class="mx-auto lg:w-full h-full lg:mt-0 "></ImageWrapper>
    </a>
    <div class="px-2">
        <div class="font-bold text-xl text-center mb-1 dark:text-neutral-50 transition">{profileConfig.name}</div>
        <div class="h-1 w-5 bg-(--primary) mx-auto rounded-full mb-2 transition"></div>
        
        <div class="text-center text-neutral-400 mb-2.5 transition">
            {profileConfig.typewriter?.enable ? (
                <TypewriterText 
                    text={profileConfig.bio || ""}
                    speed={profileConfig.typewriter.speed}
                    class="inline-block"
                />
            ) : (
                profileConfig.bio
            )}
        </div>
        
        <div class="flex flex-wrap gap-2 justify-center mb-1">
            {profileConfig.links.length > 1 && profileConfig.links.map(item =>
                <a rel="me" aria-label={item.name} href={item.url} target="_blank" 
                   class="btn-regular rounded-lg h-10 w-10 active:scale-90">
                    <Icon name={item.icon} class="text-[1.5rem]"></Icon>
                </a>
            )}
            <button
                type="button"
                aria-label="微信联系"
                aria-haspopup="dialog"
                class="wechat-trigger btn-regular rounded-lg h-10 w-10 active:scale-90"
            >
                <Icon name="fa7-brands:weixin" class="text-[1.5rem]" />
            </button>
            {profileConfig.links.length == 1 && 
                <a rel="me" aria-label={profileConfig.links[0].name} href={profileConfig.links[0].url} target="_blank"
                   class="btn-regular rounded-lg h-10 gap-2 px-3 font-bold active:scale-95">
                    <Icon name={profileConfig.links[0].icon} class="text-[1.5rem]"></Icon>
                    {profileConfig.links[0].name}
                </a>
            }
        </div>
        
        <div class="umami-stats-container">
            <hr class="my-2 border-t border-dashed border-gray-300 dark:border-gray-700" />
            <div class="text-sm text-gray-500 mt-2 text-center">
                <Icon name="fa7-solid:eye" class="inline-block mr-1 text-gray-400 text-sm align-middle" />
                <span class="site-stats-display">{i18n(I18nKey.profileStatsVisitors)} 0 · {i18n(I18nKey.profileStatsPageViews)} 0</span>
            </div>
        </div>
    </div>
</div>

<div
    class="wechat-qr-dialog pointer-events-none fixed inset-0 z-[120] hidden flex items-center justify-center p-4 opacity-0 transition duration-200"
    role="dialog"
    aria-modal="true"
    aria-label="微信联系二维码"
>
    <div class="wechat-qr-backdrop absolute inset-0 bg-black/55 backdrop-blur-sm"></div>
    <div class="card-base relative z-10 w-full max-w-sm overflow-hidden rounded-[1.75rem] border border-white/10 p-5 shadow-2xl">
        <button
            type="button"
            class="wechat-close btn-plain absolute right-3 top-3 flex h-9 w-9 items-center justify-center rounded-full"
            aria-label="关闭微信二维码"
        >
            <Icon name="material-symbols:close-rounded" class="text-xl" />
        </button>

        <div class="mb-4 pr-10">
            <div class="text-lg font-bold text-90">微信联系</div>
            <p class="mt-1 text-sm text-50">扫一扫二维码添加我，备注一下来意会更方便。</p>
        </div>

        <div class="overflow-hidden rounded-2xl bg-white p-3">
            <img
                src={wechatQrUrl}
                alt="Siky 的微信二维码"
                class="wechat-qr-image block max-h-[75vh] w-full rounded-xl object-contain"
                loading="lazy"
            />
        </div>

        <p class="wechat-qr-hint mt-3 hidden text-center text-xs text-50"></p>
    </div>
</div>
</div>

<script is:inline define:vars={{
    profileStatsPageViews: i18n(I18nKey.profileStatsPageViews),
    profileStatsVisitors: i18n(I18nKey.profileStatsVisitors),
    wechatQrUrl
}}>
    function generateStatsText(visitors, pageViews) {
        return `${profileStatsVisitors} ${visitors} · ${profileStatsPageViews} ${pageViews}`;
    }

    async function fetchSiteStats(retryCount = 0) {
        // oddmisc runtime 可能比页面脚本稍晚挂载，短暂重试几次
        if (!window.oddmisc) {
            if (retryCount < 10) {
                setTimeout(() => fetchSiteStats(retryCount + 1), 500);
                return;
            }
            return;
        }

        try {
            const stats = await window.oddmisc.getSiteStats();
            const pageViews = stats.pageviews || 0;
            const visitors = stats.visitors || 0;

            // 数据为 0 时隐藏
            document.querySelectorAll('.site-stats-display').forEach(el => {
                el.textContent = generateStatsText(visitors, pageViews);
            });
        } catch (error) {
            console.error('Error fetching site stats:', error);
            if (retryCount < 10) {
                setTimeout(() => fetchSiteStats(retryCount + 1), 2000);
                return;
            }
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => fetchSiteStats());
    } else {
        fetchSiteStats();
    }

    function openWechatDialog(wechatDialog) {
        if (!wechatDialog) return;
        wechatDialog.classList.remove('hidden');
        requestAnimationFrame(() => {
            wechatDialog.classList.remove('pointer-events-none', 'opacity-0');
        });
        document.body.classList.add('overflow-hidden');
    }

    function closeWechatDialog(wechatDialog) {
        if (!wechatDialog) return;
        wechatDialog.classList.add('pointer-events-none', 'opacity-0');
        setTimeout(() => wechatDialog.classList.add('hidden'), 200);
        document.body.classList.remove('overflow-hidden');
    }

    function initWechatDialog() {
        document.querySelectorAll('.profile-card-widget').forEach((root, index) => {
            const trigger = root.querySelector('.wechat-trigger');
            const dialog = root.querySelector('.wechat-qr-dialog');
            if (!(trigger instanceof HTMLElement) || !(dialog instanceof HTMLElement)) return;

            const dialogId = `wechat-qr-dialog-${index + 1}`;
            trigger.dataset.dialogId = dialogId;
            trigger.setAttribute('aria-controls', dialogId);

            if (!dialog.dataset.portalMounted) {
                dialog.dataset.portalMounted = 'true';
                dialog.id = dialogId;
                document.body.appendChild(dialog);
            }

            const wechatQrImage = dialog.querySelector('.wechat-qr-image');
            const wechatHint = dialog.querySelector('.wechat-qr-hint');
            if (wechatQrImage && wechatHint && !wechatQrImage.dataset.boundError) {
                wechatQrImage.dataset.boundError = 'true';
                wechatQrImage.addEventListener('error', () => {
                    wechatHint.classList.remove('hidden');
                    wechatHint.textContent = `还没找到二维码图片，请把它放到 ${wechatQrUrl}`;
                }, { once: true });
            }
        });
    }

    document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;

        if (target.closest('.wechat-trigger')) {
            const trigger = target.closest('.wechat-trigger');
            const dialogId = trigger?.getAttribute('aria-controls');
            const dialog = dialogId ? document.getElementById(dialogId) : null;
            openWechatDialog(dialog);
            return;
        }

        if (target.closest('.wechat-close') || target.closest('.wechat-qr-backdrop')) {
            const dialog = target.closest('.wechat-qr-dialog');
            closeWechatDialog(dialog);
        }
    });

    document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
            document.querySelectorAll('.wechat-qr-dialog').forEach((dialog) => {
                closeWechatDialog(dialog);
            });
        }
    });

    initWechatDialog();
    document.addEventListener('astro:page-load', initWechatDialog);
</script>
